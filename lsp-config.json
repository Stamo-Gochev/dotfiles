{
    "lspServers": {
        "typescript": {
            "command": "typescript-language-server",
            "args": [
                "--stdio"
            ],
            "fileExtensions": {
                ".ts": "typescript",
                ".tsx": "typescriptreact",
                ".js": "javascript",
                ".jsx": "javascriptreact"
            }
        },
        "roslyn": {
            "command": "roslyn-language-server",
            "args": [
                "--stdio",
                "--logLevel=Information"
            ],
            "fileExtensions": {
                ".cs": "csharp",
                ".razor": "razor"
            }
        }
    }
}