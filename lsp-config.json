{
    "lspServers": {
        "typescript": {
            "command": "typescript-language-server",
            "args": [
                "--stdio"
            ],
            "fileExtensions": {
                ".ts": "typescript",
                ".tsx": "typescriptreact",
                ".js": "javascript",
                ".jsx": "javascriptreact"
            }
        },
        "roslyn": {
            "command": "roslyn-language-server",
            "args": [
                "--stdio",
                "--logLevel=Information"
            ],
            "fileExtensions": {
                ".cs": "csharp",
                ".razor": "razor"
            }
        },
        "python": {
            "command": "pyright-langserver",
            "args": [
                "--stdio"
            ],
            "fileExtensions": {
                ".py": "python",
                ".pyi": "python"
            }
        },
        "gopls": {
            "command": "gopls",
            "args": [
                "serve"
            ],
            "fileExtensions": {
                ".go": "go"
            }
        },
        "clangd": {
            "command": "clangd",
            "args": [
                "--background-index"
            ],
            "fileExtensions": {
                ".cpp": "cpp",
                ".cxx": "cpp",
                ".cc": "cpp",
                ".c": "c",
                ".h": "cpp",
                ".hpp": "cpp"
            }
        }
    }
}